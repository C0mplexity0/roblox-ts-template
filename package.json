{
	"name": "roblox-ts-template",
	"version": "0.0.0",
	"scripts": {
		"build:main": "rbxtsc -p ./places/main -i ./include",
		"watch:main": "rbxtsc -w -p ./places/main -i ./include",
		"serve:main": "rojo serve ./places/main",
		"dev:main": "concurrently \"pnpm run watch:main\" \"pnpm run serve:main\""
	},
	"devDependencies": {
		"@rbxts/compiler-types": "3.0.0-types.0",
		"@rbxts/types": "^1.0.915",
		"@typescript-eslint/eslint-plugin": "^5.29.0",
		"@typescript-eslint/parser": "^5.29.0",
		"concurrently": "^9.2.1",
		"eslint": "^8.18.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-prettier": "^4.0.0",
		"eslint-plugin-roblox-ts": "^0.0.34",
		"prettier": "^2.7.1",
		"rbxts-transformer-flamework": "^1.3.2",
		"roblox-ts": "3.0.0-dev-9165cde",
		"typescript": "^5.5.3"
	},
	"dependencies": {
		"@flamework/components": "^1.3.2",
		"@flamework/core": "^1.3.2",
		"@flamework/networking": "^1.3.2",
		"@rbxts/services": "^1.6.0",
		"@rbxts/signal": "^1.1.1"
	}
}
